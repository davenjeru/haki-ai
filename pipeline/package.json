{
  "name": "haki-ai-pipeline",
  "version": "1.0.0",
  "description": "PDF chunking pipeline for Haki AI — parses Kenyan law PDFs and uploads citation-tagged chunks to S3 for Bedrock KB ingestion.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-vm-modules dist/run.js",
    "dev": "tsx src/run.ts",
    "dev:local": "AWS_ENDPOINT_URL=http://localhost:4566 tsx src/run.ts",
    "chunk": "tsx src/chunk-laws.ts",
    "chunk:local": "AWS_ENDPOINT_URL=http://localhost:4566 tsx src/chunk-laws.ts",
    "local:start": "localstack start -d",
    "local:stop": "localstack stop"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@llamaindex/liteparse": "latest",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
