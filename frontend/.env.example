# Copy to .env.local and fill in values. Never commit .env.local.
# See vite.config.ts and src/api/chatClient.ts for how these are used.

# ── Local dev (Vite proxy) ────────────────────────────────────────────────────
# Node-only: Vite dev server proxies /chat → this URL. Not sent to the browser.
# Run: cd backend && ENV=local uv run server_local.py
LOCAL_API_URL=http://localhost:8080

# Empty string = real API mode via Vite proxy (local dev).
VITE_API_BASE_URL=

# ── Production ────────────────────────────────────────────────────────────────
# VITE_API_BASE_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com
# (LOCAL_API_URL is not needed in production — browser calls the URL directly)

# ── Mock mode (no backend required) ──────────────────────────────────────────
# VITE_USE_MOCK=true
# (or simply omit VITE_API_BASE_URL entirely — undefined = mock mode)

# POST path relative to base (default: /chat)
# VITE_CHAT_PATH=/chat
