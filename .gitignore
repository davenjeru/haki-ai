# Environment secrets — keep .env.example files committed
.env
.env.local
.env.*.local

# Node
**/node_modules/
**/dist/

# Pipeline
pipeline/.tmp-chunks/
pipeline/*.traineddata

# Terraform — state lives in the s3 backend (workspace-isolated), never on disk
infra/.terraform/
infra/.terraform.lock.hcl
infra/*.tfstate
infra/*.tfstate.backup
infra/terraform.tfvars.local
infra/modules/compute/lambda.zip
infra/modules/compute/lambda-layer.zip
infra/modules/compute/.layer-build/

# LocalStack volume (certs + license)
pipeline/volume/

# Claude Code local settings
.claude/

# Cursor local settings (workspace MCP config holds API keys)
.cursor/

# Agent skills — installed by `npx skills add`; reproducible from skills-lock.json
.agents/

# Eval harness outputs (generated; only the directory itself is tracked)
backend/evals/reports/*
!backend/evals/reports/.gitkeep

# Python (uv)
backend/.venv/
**/__pycache__/
*.pyc
*.py.bak
# Local ChromaDB store lives next to the ingest + eval entry points.
# Ingest used to create it under backend/app/ by mistake (since fixed),
# so we pattern-match any `.local-vectorstore/` anywhere under backend/
# to cover historical and future locations.
backend/**/.local-vectorstore/

# macOS
.DS_Store
