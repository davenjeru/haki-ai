# Environment secrets — keep .env.example files committed
.env
.env.local
.env.*.local

# Node
**/node_modules/
**/dist/

# Pipeline
pipeline/.tmp-chunks/
pipeline/*.traineddata

# Terraform — state lives in the s3 backend (workspace-isolated), never on disk
infra/.terraform/
infra/.terraform.lock.hcl
infra/*.tfstate
infra/*.tfstate.backup
infra/terraform.tfvars.local
infra/modules/compute/lambda.zip
infra/modules/compute/lambda-layer.zip
infra/modules/compute/.layer-build/

# LocalStack volume (certs + license)
pipeline/volume/

# Claude Code local settings
.claude/

# Python (uv)
backend/.venv/
backend/__pycache__/
backend/.local-vectorstore/

# macOS
.DS_Store
