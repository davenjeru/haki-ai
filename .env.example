# ── Haki AI root env file ──────────────────────────────────────────────
#
# Copy this file to `.env` and fill in the blanks. No secrets are stored
# in the repo; everything sensitive (LangSmith key, LocalStack token) is
# configured here and loaded by `make setup` / `make dev`.
#
# Variables with no default MUST be provided.

# ── LocalStack (required for `make dev`) ───────────────────────────────
# Get a free Pro token at https://app.localstack.cloud — required for
# S3 Vectors + Bedrock KB emulation. Leave empty to run LocalStack
# Community (most pipeline targets still work).
LOCALSTACK_AUTH_TOKEN=

# Persist LocalStack state (S3 buckets, objects, secrets, etc.) across
# container restarts. Requires LocalStack Pro — no-op on Community.
# Data lives under ~/.cache/localstack/volume by default.
LOCALSTACK_PERSISTENCE=1

# ── LangSmith tracing (optional but recommended) ───────────────────────
# Traces every LangGraph invocation so you can inspect supervisor routes
# and retrieval chains in https://smith.langchain.com.
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=haki-ai
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── AWS ────────────────────────────────────────────────────────────────
# Only needed for `make apply` (real AWS) and for Bedrock model calls
# (Bedrock is never emulated — even locally we hit real AWS for LLM /
# embedding / rerank calls).
AWS_REGION=us-east-1
AWS_PROFILE=default

# ── Fine-tuned model toggle (Phase 4b) ─────────────────────────────────
# Set to `true` once you've run scripts/run-finetune.sh AND applied
# Terraform with -var deploy_endpoint=true. Leave as `false` to always
# route through Claude on Bedrock.
USE_FINETUNED_MODEL=false
SAGEMAKER_ENDPOINT_NAME=
